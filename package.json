  "dependencies": {
    "next": "^16.2.9"
  },
  "peerDependencies": {
    "next": "^16.2.9"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^4.5.4",
    "next": "^16.2.9"
  }
